    },
    {
      "fieldname": "data_categories",
      "fieldtype": "Small Text",
      "label": "Data Categories Covered",
      "description": "Personal data categories covered by this consent (e.g. NRIC, Salary, Bank Account, EPF Number, SOCSO Number, Tax File Number).",
      "default": "NRIC, Salary, Bank Account, EPF Number, SOCSO Number, Tax File Number"
    },
    {
      "fieldname": "section_withdrawal",
      "fieldtype": "Section Break",
      "label": "Consent Withdrawal"
    },
    {
      "fieldname": "consent_withdrawn_date",
      "fieldtype": "Datetime",
      "label": "Consent Withdrawn Date",
