FROM frappe/erpnext:v16.7.0

USER frappe
WORKDIR /home/frappe/frappe-bench

# Clone myinvois app (bench get-app fails due to uv resolving frappe's git-pinned pypika)
RUN git clone --depth 1 --branch main https://github.com/ERPGulf/myinvois.git apps/myinvois_erpgulf

# Clone hrms (HR & Payroll) — separated from ERPNext core in v15+
RUN git clone --depth 1 --branch version-16 https://github.com/frappe/hrms.git apps/hrms

# Install with pip --no-deps: frappe/erpnext are already in the venv
RUN /home/frappe/frappe-bench/env/bin/pip install --quiet --no-deps -e apps/myinvois_erpgulf

# hrms has its own Python dependencies (install with deps)
RUN /home/frappe/frappe-bench/env/bin/pip install --quiet -e apps/hrms

# Copy and install lhdn_payroll_integration custom app (built locally, not on PyPI)
COPY lhdn_payroll_integration apps/lhdn_payroll_integration
RUN /home/frappe/frappe-bench/env/bin/pip install --quiet --no-deps -e apps/lhdn_payroll_integration

# Copy and install prisma_assistant custom app (general-purpose AI chat)
COPY prisma_assistant apps/prisma_assistant
RUN /home/frappe/frappe-bench/env/bin/pip install --quiet --no-deps -e apps/prisma_assistant

# qrcode is used by lhdn_payroll_integration/utils/qr_utils.py at import time
RUN /home/frappe/frappe-bench/env/bin/pip install --quiet "qrcode[pil]"

# Clone and install Frappe Assistant Core (MCP server for LLM ↔ ERPNext integration)
RUN git clone --depth 1 --branch main https://github.com/buildswithpaul/Frappe_Assistant_Core apps/frappe_assistant_core
RUN /home/frappe/frappe-bench/env/bin/pip install --quiet -e apps/frappe_assistant_core
# Restore frappe-pinned versions overridden by frappe_assistant_core's requirements
RUN /home/frappe/frappe-bench/env/bin/pip install --quiet "beautifulsoup4~=4.13.5" "chardet~=5.2.0"

# Create assets symlinks so /assets/<app>/ is served by nginx
RUN ln -sf /home/frappe/frappe-bench/apps/myinvois_erpgulf/myinvois_erpgulf/public \
    /home/frappe/frappe-bench/sites/assets/myinvois_erpgulf \
 && ln -sf /home/frappe/frappe-bench/apps/hrms/hrms/public \
    /home/frappe/frappe-bench/sites/assets/hrms \
 && ln -sf /home/frappe/frappe-bench/apps/lhdn_payroll_integration/lhdn_payroll_integration/public \
    /home/frappe/frappe-bench/sites/assets/lhdn_payroll_integration \
 && ln -sf /home/frappe/frappe-bench/apps/frappe_assistant_core/frappe_assistant_core/public \
    /home/frappe/frappe-bench/sites/assets/frappe_assistant_core \
 && ln -sf /home/frappe/frappe-bench/apps/prisma_assistant/prisma_assistant/public \
    /home/frappe/frappe-bench/sites/assets/prisma_assistant

# Demo login: patch login page + expose test data seed as importable module
COPY frappe_patches/login.html apps/frappe/frappe/www/login.html
COPY frappe_patches/login.js apps/frappe/frappe/templates/includes/login/login.js
COPY frappe_patches/login.py apps/frappe/frappe/www/login.py
COPY setup_test_data.py apps/frappe/frappe/setup_test_data.py

# E-Invoice desktop icon: put prisma_einvoice.svg in the Frappe desktop_icons folder
# so get_desktop_icon() finds it for both the home grid and workspace sidebar.
# File name must match frappe.scrub(Desktop Icon label) = "e_invoice".
RUN mkdir -p apps/myinvois_erpgulf/myinvois_erpgulf/public/icons/desktop_icons/solid \
 && mkdir -p apps/myinvois_erpgulf/myinvois_erpgulf/public/icons/desktop_icons/subtle \
 && cp apps/myinvois_erpgulf/myinvois_erpgulf/public/images/prisma_einvoice.svg \
       apps/myinvois_erpgulf/myinvois_erpgulf/public/icons/desktop_icons/solid/e_invoice.svg \
 && cp apps/myinvois_erpgulf/myinvois_erpgulf/public/images/prisma_einvoice.svg \
       apps/myinvois_erpgulf/myinvois_erpgulf/public/icons/desktop_icons/subtle/e_invoice.svg

# Tabler Icons FILLED: solid/filled icons replacing Frappe's Lucide outline sprite.
# IDs renamed tabler-filled-NAME -> icon-NAME; inline fill styles bypass Frappe's fill:transparent CSS.
# Regenerate with: uv run python replace_frappe_icons.py filled   (or 'outline' for thin strokes)
COPY frappe_patches/tabler_lucide_icons.svg apps/frappe/frappe/public/icons/lucide/icons.svg
COPY frappe_patches/tabler_lucide_icons.svg apps/frappe/frappe/public/icons/lucide.svg

# Prisma logo — placed at /tmp so setup_test_data.setup_prisma_branding() can find it
COPY prisma_logo.png /tmp/prisma_logo.png
